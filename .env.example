# Argus Configuration
# Copy this file to .env and fill in your API keys

# ============================================================
# AI Provider - Strix-style (recommended)
# ============================================================
# Format: provider/model
# Examples: openai/gpt-4o, anthropic/claude-sonnet-4, google/gemini-2.5-flash
#           groq/llama3-70b-8192, mistral/mistral-large, ollama/llama3
STRIX_LLM=openai/gpt-4o
LLM_API_KEY=sk-...

# Alternative: use individual provider keys
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# GROQ_API_KEY=...
# MISTRAL_API_KEY=...

# DeepSeek v4 Flash via OpenCode API
# STRIX_LLM=opencode/deepseek-v4-flash
# OPENCODE_API_KEY=sk-...
# OPENCODE_API_BASE=https://api.opencode.ai/v1

# LiteLLM configuration
# LITELLM_API_BASE=          # Custom API base URL
# LITELLM_MAX_TOKENS=4096
# LITELLM_FALLBACKS=gpt-4o-mini,claude-3-haiku-20240307

# Reasoning effort (none/minimal/low/medium/high/xhigh)
STRIX_REASONING_EFFORT=high

# LLM timeout & retries
LLM_TIMEOUT=300
LLM_MAX_RETRIES=5

# ============================================================
# AI Efficiency Features (v2.1+)
# ============================================================

# Model Router: auto-selects cheapest model per task
# Override individual task models in argus/agents/llm_client.py:MODEL_ROUTES
# AI_MODEL_ROUTER_ENABLED=true (default: true)

# Semantic Cache: embedding-based similarity matching for LLM prompts
# Requires: pip install sentence-transformers
# SEMANTIC_CACHE_ENABLED=true
# SEMANTIC_SIMILARITY_THRESHOLD=0.88

# Mixture of Agents: uses 3 small models + 1 aggregator instead of 1 large model
# 80% cost reduction while maintaining quality
# MOA_ENSEMBLE_MODELS=groq/llama3-8b,groq/llama3-8b,groq/llama3-8b
# MOA_AGGREGATOR_MODEL=anthropic/claude-sonnet-4

# Scan depth dynamic token control
# SCAN_DEPTH_QUICK_TOKENS=500
# SCAN_DEPTH_STANDARD_TOKENS=1500
# SCAN_DEPTH_DEEP_TOKENS=3000

# Online learning: cross-session technique effectiveness tracking
# LEARNED_PATTERNS_PATH=~/.argus/learned_patterns.jsonl
# LLM_PERFORMANCE_PATH=~/.argus/llm_performance.jsonl

# ============================================================
# Scanning Configuration
# ============================================================
MAX_CONCURRENT_AGENTS=5
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# ============================================================
# Browser Automation
# ============================================================
HEADLESS_BROWSER=true
BROWSER_TIMEOUT=30000

# ============================================================
# Output Configuration
# ============================================================
OUTPUT_DIR=./argus_results
VERBOSE=false
DEBUG=false

# ============================================================
# Proxy Configuration (optional)
# ============================================================
# HTTP_PROXY=http://localhost:8080
# HTTPS_PROXY=http://localhost:8080

# ============================================================
# Rate Limiting
# ============================================================
REQUESTS_PER_SECOND=10
BURST_SIZE=20
